<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="Student-Project-StudentProject">

        <!-- Hibernate Provider -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entity Classes -->
        <class>java_advanced.framework.hibernate_jpa.one_to_many.entity.Project</class>
        <class>java_advanced.framework.hibernate_jpa.one_to_many.entity.Student</class>
        <class>java_advanced.framework.hibernate_jpa.one_to_many.entity.StudentProject</class>
        
        <properties>

            <!-- JDBC Configuration -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>

            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/student_project_db"/>

            <property name="jakarta.persistence.jdbc.user"
                      value="mohit"/>

            <property name="jakarta.persistence.jdbc.password"
                      value="1234"/>

            <!-- Hibernate Properties -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>

            <property name="hibernate.hbm2ddl.auto"
                      value="create"/>

            <property name="hibernate.show_sql"
                      value="true"/>

            <property name="hibernate.format_sql"
                      value="true"/>

        </properties>

    </persistence-unit>

</persistence>